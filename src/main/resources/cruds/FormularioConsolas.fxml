<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="716.0" prefWidth="1120.0" style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 10; -fx-background-radius: 10;" stylesheets="@../styles/formularioconsolas.css" 
            xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controllers.FormularioConsolasController">
    <children>
        <Text layoutX="30.0" layoutY="37.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Formulario para Consolas" textAlignment="CENTER" underline="true" wrappingWidth="1061.0">
            <font>
                <Font name="System Bold Italic" size="21.0" />
            </font>
        </Text>

        <!-- Formulario organizado en GridPane -->
        <GridPane hgap="10" layoutX="30.0" layoutY="70.0" vgap="12">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="120.0" />
                <ColumnConstraints halignment="LEFT" minWidth="300.0" />
            </columnConstraints>

            <!-- ComboBox para selección de consola -->
            <Label text="Seleccionar Consola:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <ComboBox fx:id="combo_consolas" prefHeight="43.0" prefWidth="309.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txt_nombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Año:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="txt_anio" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Fabricante:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="txt_fabricante" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Generación:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextField fx:id="txt_generacion" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label text="Región:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <TextField fx:id="txt_region" GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <Label text="Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <TextField fx:id="txt_tipo" GridPane.columnIndex="1" GridPane.rowIndex="6" />

            <Label text="Procesador:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
            <TextField fx:id="txt_procesador" GridPane.columnIndex="1" GridPane.rowIndex="7" />

            <Label text="Memoria:" GridPane.columnIndex="0" GridPane.rowIndex="8" />
            <TextField fx:id="txt_memoria" GridPane.columnIndex="1" GridPane.rowIndex="8" />

            <Label text="Almacenamiento:" GridPane.columnIndex="0" GridPane.rowIndex="9" />
            <TextField fx:id="txt_almacenamiento" GridPane.columnIndex="1" GridPane.rowIndex="9" />

            <Label text="Fecha Lanzamiento:" GridPane.columnIndex="0" GridPane.rowIndex="10" />
            <TextField fx:id="txt_fecha_lanzamiento" GridPane.columnIndex="1" GridPane.rowIndex="10" />
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <!-- Botonera -->
        <HBox layoutX="168.0" layoutY="615.0" spacing="15.0">
            <children>
                <Button fx:id="btn_guardar" styleClass="boton-accion">
                    <graphic>
                        <FontAwesomeIconView glyphName="PLUS" styleClass="icono-boton" />
                    </graphic>
                    <text>Añadir</text>
                </Button>
                <Button fx:id="btn_editar" styleClass="boton-accion">
                    <graphic>
                        <FontAwesomeIconView glyphName="PENCIL" styleClass="icono-boton" />
                    </graphic>
                    <text>Editar</text>
                </Button>
                <Button fx:id="btn_eliminar" styleClass="boton-accion">
                    <graphic>
                        <FontAwesomeIconView glyphName="TRASH" styleClass="icono-boton" />
                    </graphic>
                    <text>Eliminar</text>
                </Button>
            </children>
        </HBox>

        <!-- Botón para cambiar imagen -->
        <Button fx:id="btn_cambiar_imagen" layoutX="733.0" layoutY="615.0" prefHeight="49.0" prefWidth="223.0" styleClass="boton-accion" text="Cambiar Imagen" />
      <Pane layoutX="579.0" layoutY="70.0" prefHeight="509.0" prefWidth="499.0" style="-fx-border-color: #000000; -fx-border-radius: 4px;">
         <children>
      
              <!-- Imagen de la consola -->
              <ImageView fx:id="imagen_consola_form" fitHeight="509.0" fitWidth="499.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </Pane>
    </children>
</AnchorPane>
