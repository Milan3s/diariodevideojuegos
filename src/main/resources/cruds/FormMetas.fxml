<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="formularioMetas" prefHeight="615.0" prefWidth="920.0" styleClass="formulario-meta" stylesheets="@../styles/formmetas.css" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FormMetasController">

    <VBox spacing="10" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="80.0">

        <!-- Título del formulario -->
        <Text fx:id="tituloFormulario" text="Formulario de Meta" styleClass="titulo-meta" />

        <HBox fx:id="boxMeta" spacing="20" visible="false">
            <Label text="Meta" styleClass="label-meta" />
            <TextField fx:id="txtValorMeta" promptText="Cantidad meta" styleClass="input-meta" />
            <Label text="Actual" styleClass="label-meta" />
            <TextField fx:id="txtValorActual" promptText="Progreso actual" styleClass="input-meta" />
        </HBox>

        <HBox fx:id="boxJuegos" spacing="20" visible="false">
            <Label text="Juegos Objetivo" styleClass="label-meta" />
            <TextField fx:id="txtJuegosObjetivoMeta" promptText="Total a completar" styleClass="input-meta" />
            <Label text="Completados" styleClass="label-meta" />
            <TextField fx:id="txtJuegosCompletadosMeta" promptText="Ya completados" styleClass="input-meta" />
        </HBox>

        <HBox fx:id="boxFabricante" spacing="20" visible="false">
            <Label text="Fabricante" styleClass="label-meta" />
            <TextField fx:id="txtFabricanteMeta" promptText="Fabricante (opcional)" styleClass="input-meta" />
        </HBox>

        <HBox fx:id="boxConsola" spacing="20" visible="false">
            <Label text="Consola" styleClass="label-meta" />
            <ComboBox fx:id="comboConsolaMeta" promptText="Selecciona consola" styleClass="input-meta" prefWidth="250" />
        </HBox>

        <HBox fx:id="boxExtensible" spacing="20" visible="false">
            <Label text="Motivo" styleClass="label-meta" />
            <TextField fx:id="txtMotivoMeta" promptText="Motivo del extensible" styleClass="input-meta" />
            <Label text="Fecha Evento" styleClass="label-meta" />
            <DatePicker fx:id="dpFechaEventoMeta" styleClass="input-meta" />
        </HBox>

        <HBox fx:id="boxFechas" spacing="20" visible="false">
            <Label text="Fecha Inicio" styleClass="label-meta" />
            <DatePicker fx:id="dpInicioMeta" styleClass="input-meta" />
            <Label text="Fecha Fin" styleClass="label-meta" />
            <DatePicker fx:id="dpFinMeta" styleClass="input-meta" />
        </HBox>

        <HBox spacing="20">
            <Label text="Descripción" styleClass="label-meta" />
            <TextField fx:id="txtDescripcionMeta" promptText="Descripción de la meta" styleClass="input-meta" prefWidth="400" />
        </HBox>

    </VBox>

    <!-- Botones -->
    <HBox alignment="CENTER" spacing="12" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Button fx:id="btnGuardarMeta" styleClass="meta-button" text="Guardar">
            <graphic>
                <FontAwesomeIconView glyphName="SAVE" styleClass="control-icon" />
            </graphic>
        </Button>
        <Button fx:id="btnCancelarMeta" styleClass="meta-button" text="Cancelar">
            <graphic>
                <FontAwesomeIconView glyphName="CLOSE" styleClass="control-icon" />
            </graphic>
        </Button>
    </HBox>

</AnchorPane>
