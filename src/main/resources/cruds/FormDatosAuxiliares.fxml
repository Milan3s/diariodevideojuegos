<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="200.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.FormDatosAuxiliaresController"
            styleClass="mainFxmlClass">

    <VBox layoutX="30.0" layoutY="30.0" spacing="15.0" prefWidth="340.0" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30" AnchorPane.topAnchor="30" AnchorPane.bottomAnchor="30">
    
        <Label fx:id="lblTitulo" text="Agregar/Editar" styleClass="form-titulo" />

        <!-- Combo para elegir tipo -->
        <ComboBox fx:id="comboTipoDato" promptText="Selecciona tipo de dato auxiliar" />

        <!-- Campo de texto -->
        <TextField fx:id="campoNombre" promptText="Nombre del dato" />

        <!-- Botones -->
        <HBox spacing="10.0">
            <Button fx:id="btnGuardar" text="Guardar" onAction="#guardarDatoAuxiliar" defaultButton="true" />
            <Button fx:id="btnCancelar" text="Cancelar" onAction="#cancelar" cancelButton="true" />
        </HBox>
    </VBox>


   
</AnchorPane>
