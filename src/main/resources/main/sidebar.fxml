<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="rootPane" prefHeight="600" prefWidth="800" styleClass="root"
            stylesheets="@../styles/sidebar.css"
            xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.SidebarController">

    <children>
        <BorderPane fx:id="borderPane" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                    AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <!-- Sidebar lateral -->
            <left>
                <VBox fx:id="sidebar" alignment="TOP_CENTER" prefWidth="200" spacing="15" styleClass="sidebar">
                    <padding>
                        <Insets bottom="10" left="10" right="10" top="20" />
                    </padding>

                    <Text fx:id="tituloSidebar" styleClass="sidebar-title" text="Menú" />

                    <!-- Botón principal de Inicio -->
                    <Button fx:id="btnInicio" onAction="#toggleSubmenuInicio" prefWidth="180"
                            styleClass="sidebar-button" text="Inicio" />

                    <!-- Submenú desplegable asociado a Inicio -->
                    <VBox fx:id="contenedorSubmenuInicio" spacing="0" alignment="TOP_CENTER">
                        <Label fx:id="flechaSubmenuInicio" text="▲" styleClass="submenu-arrow" visible="false" managed="false"/>
                        <VBox fx:id="submenuInicio" styleClass="submenu-metas" visible="false" managed="false">
                            <Button fx:id="btnResumenInicio" onAction="#handleResumenInicio" text="Resumen del Día" styleClass="submenu-button" />
                            <Button fx:id="btnMetasTwitch" onAction="#handleMetasTwitch" text="Metas Twitch" styleClass="submenu-button" />
                            <Button fx:id="btnMetasEspecificas" onAction="#handleMetasEspecificas" text="Metas Específicas" styleClass="submenu-button" />
                            <Button fx:id="btnMejorasCanal" onAction="#handleMejorasCanal" text="Mejoras del Canal" styleClass="submenu-button" />
                            <Button fx:id="btnEventosExtensibles" onAction="#handleEventosExtensibles" text="Eventos Extensibles" styleClass="submenu-button" />
                        </VBox>
                    </VBox>

                    <!-- Otros botones del menú -->
                    <Button fx:id="btnConsolas" onAction="#handleConsolas" prefWidth="180"
                            styleClass="sidebar-button" text="Consolas" />

                    <Button fx:id="btnJuegos" onAction="#handleJuegos" prefWidth="180"
                            styleClass="sidebar-button" text="Juegos" />

                    <Button fx:id="btnLogros" onAction="#handleLogros" prefWidth="180"
                            styleClass="sidebar-button" text="Logros" />

                    <Button fx:id="btnModerador" onAction="#handleModerador" prefWidth="180"
                            styleClass="sidebar-button" text="Moderador" />

                    <Button fx:id="btnDatosAuxiliares" onAction="#handleDatosAuxiliares" prefWidth="180"
                            styleClass="sidebar-button" text="Datos auxiliares" />
                </VBox>
            </left>

            <!-- Contenido central -->
            <center>
                <StackPane fx:id="contentArea" styleClass="content-area" />
            </center>
        </BorderPane>
    </children>
</AnchorPane>
