<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<Pane fx:id="panel_principal" prefHeight="715.0" prefWidth="361.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SidebarController">
   <children>
      <VBox alignment="TOP_CENTER" layoutY="20.0" prefWidth="361.0" spacing="25.0">
         <children>

            <!-- TÍTULO -->
            <Text text="Menú">
               <font><Font size="40.0" /></font>
            </Text>

            <!-- BOTÓN INICIO -->
            <Button fx:id="btnIInicio" onAction="#accion_inicio" prefHeight="40.0" prefWidth="200.0">
               <graphic>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <children>
                        <FontAwesomeIconView glyphName="HOME" size="18">
                           <HBox.margin><Insets left="10.0" /></HBox.margin>
                        </FontAwesomeIconView>
                        <Text text="Inicio">
                           <font><Font size="17.0" /></font>
                        </Text>
                     </children>
                  </HBox>
               </graphic>
            </Button>

            <!-- BOTÓN JUEGOS -->
            <Button fx:id="btnJuegos" onAction="#accion_juegos" prefHeight="40.0" prefWidth="200.0">
               <graphic>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <children>
                        <FontAwesomeIconView glyphName="GAMEPAD" size="18">
                           <HBox.margin><Insets left="10.0" /></HBox.margin>
