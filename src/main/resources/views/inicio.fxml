<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="root" stylesheets="@../styles/vistas.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.InicioController">

    <!-- Título -->
    <Text fx:id="tituloResumen" layoutX="30.0" layoutY="40.0" styleClass="inicio-titulo" text="Resumen del Diario" />

    <!-- Grid principal: Totales -->
    <GridPane fx:id="gridResumen" hgap="40" layoutX="9.0" layoutY="74.0" prefHeight="480.0" prefWidth="490.0" styleClass="inicio-grid" vgap="40">

        <!-- Tarjeta 1: Juegos -->
        <HBox alignment="CENTER" prefHeight="150" prefWidth="200" spacing="10" styleClass="card-inicio" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <VBox alignment="CENTER" prefHeight="78.0" prefWidth="237.0" spacing="5">
                <Text styleClass="card-label" text="Juegos" />
                <Text fx:id="txt_juegos_total" styleClass="card-value" />
            </VBox>
        </HBox>

        <!-- Tarjeta 2: Logros -->
        <HBox alignment="CENTER" prefHeight="150" prefWidth="200" spacing="10" styleClass="card-inicio" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <VBox alignment="CENTER" prefHeight="78.0" prefWidth="185.0" spacing="5">
                <Text styleClass="card-label" text="Logros" />
                <Text fx:id="txt_logros_total" styleClass="card-value" />
            </VBox>
        </HBox>

        <!-- Tarjeta 3: Consolas -->
        <HBox alignment="CENTER" prefHeight="150" prefWidth="200" spacing="10" styleClass="card-inicio" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <VBox alignment="CENTER" prefHeight="78.0" prefWidth="211.0" spacing="5">
                <Text styleClass="card-label" text="Consolas" />
                <Text fx:id="txt_consolas_total" styleClass="card-value" />
            </VBox>
        </HBox>

        <!-- Tarjeta 4: Eventos -->
        <HBox alignment="CENTER" prefHeight="150" prefWidth="200" spacing="10" styleClass="card-inicio" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <VBox alignment="CENTER" prefHeight="78.0" prefWidth="176.0" spacing="5">
                <Text styleClass="card-label" text="Eventos" />
                <Text fx:id="txt_eventos_total" styleClass="card-value" />
            </VBox>
        </HBox>

        <!-- Tarjeta 5: Metas -->
        <HBox alignment="CENTER" prefHeight="150" prefWidth="200" spacing="10" styleClass="card-inicio" GridPane.columnIndex="0" GridPane.rowIndex="2">
            <VBox alignment="CENTER" prefHeight="78.0" prefWidth="201.0" spacing="5">
                <Text styleClass="card-label" text="Metas" />
                <Text fx:id="txt_metas_total" styleClass="card-value" />
            </VBox>
        </HBox>

        <!-- Tarjeta 6: Seguidores -->
        <HBox alignment="CENTER" prefHeight="150" prefWidth="200" spacing="10" styleClass="card-inicio" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <VBox alignment="CENTER" prefHeight="117.0" prefWidth="158.0" spacing="5">
                <Text styleClass="card-label" text="Seguidores" />
                <Text fx:id="txt_seguidores_total" styleClass="card-value" />
            </VBox>
        </HBox>

        <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
        </columnConstraints>

        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>

    <!-- Grid secundario: Detalles de metas, mejoras y extensibles -->
    <GridPane fx:id="gridMetasDetalle" hgap="30" layoutX="520.0" layoutY="60.0" prefWidth="260.0" styleClass="inicio-grid" vgap="20">

        <!-- Meta 1 -->
        <HBox alignment="CENTER_LEFT" prefHeight="100" prefWidth="260" spacing="10" styleClass="card-inicio" GridPane.rowIndex="0">
            <VBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 10;">
                <Text styleClass="card-label" text="Meta: 100 Seguidores" />
                <Text styleClass="card-sub" text="Progreso: 60%" />
            </VBox>
        </HBox>

        <!-- Meta 2 -->
        <HBox alignment="CENTER_LEFT" prefHeight="100" prefWidth="260" spacing="10" styleClass="card-inicio" GridPane.rowIndex="1">
            <VBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 10;">
                <Text styleClass="card-label" text="Meta: 50 Juegos Completados" />
                <Text styleClass="card-sub" text="¡Meta alcanzada!" />
            </VBox>
        </HBox>

        <!-- Mejoras del canal -->
        <HBox alignment="CENTER_LEFT" prefHeight="100" prefWidth="260" spacing="10" styleClass="card-inicio" GridPane.rowIndex="2">
            <VBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 10;">
                <Text styleClass="card-label" text="Mejoras del canal" />
                <Text styleClass="card-sub" text="Mister Pi + iluminación" />
            </VBox>
        </HBox>

        <!-- Extensible por aniversario -->
        <HBox alignment="CENTER_LEFT" prefHeight="100" prefWidth="260" spacing="10" styleClass="card-inicio" GridPane.rowIndex="3">
            <VBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 10;">
                <Text styleClass="card-label" text="Próximo extensible por aniversario del canal" />
                <Text styleClass="card-sub" text="Faltan 5 días" />
            </VBox>
        </HBox>
      <columnConstraints>
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>

    </GridPane>
</AnchorPane>
