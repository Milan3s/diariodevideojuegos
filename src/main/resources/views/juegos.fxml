<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="722.0" prefWidth="1167.0" styleClass="mainFxmlClass" stylesheets="@../styles/juegos.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.JuegosController">

    <!-- Título -->
    <Text fx:id="tituloJuegos" layoutX="30.0" layoutY="40.0" styleClass="inicio-titulo" text="Juegos" />

    <!-- HBox para los botones: Añadir, Editar, Eliminar -->
    <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="60.0" spacing="10.0">
        <!-- Botón Añadir -->
        <Button layoutX="10.0" onAction="#abrirModalAgregarJuego" styleClass="juegos-button" text="Añadir juego" />
        <!-- Botón Editar -->
        <Button fx:id="btnEditar" onAction="#editarJuego" styleClass="juegos-button" text="Editar" />
        <!-- Botón Eliminar -->
        <Button fx:id="btnEliminar" onAction="#eliminarJuego" styleClass="juegos-button" text="Eliminar" />
    </HBox>

    <!-- ListView -->
    <ListView fx:id="listaJuegos" layoutX="30.0" layoutY="116.0" prefHeight="606.0" prefWidth="248.0" styleClass="lista-juegos" />

    <!-- Detalles (Card) -->
    <AnchorPane layoutX="300.0" layoutY="116.0" prefHeight="606.0" prefWidth="733.0" styleClass="detalle-card">
        <Label layoutX="20.0" layoutY="20.0" styleClass="detalle-titulo" text="Nombre" />
        <Label fx:id="lblNombre" layoutX="180.0" layoutY="20.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="55.0" styleClass="detalle-titulo" text="Género" />
        <Label fx:id="lblGenero" layoutX="180.0" layoutY="55.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="90.0" styleClass="detalle-titulo" text="Editor" />
        <Label fx:id="lblEditor" layoutX="180.0" layoutY="90.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="125.0" styleClass="detalle-titulo" text="Desarrollador" />
        <Label fx:id="lblDesarrollador" layoutX="180.0" layoutY="125.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="160.0" styleClass="detalle-titulo" text="Fecha de lanzamiento" />
        <Label fx:id="lblFecha" layoutX="180.0" layoutY="160.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="195.0" styleClass="detalle-titulo" text="Modo de juego" />
        <Label fx:id="lblModo" layoutX="180.0" layoutY="195.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="230.0" styleClass="detalle-titulo" text="Recomendado" />
        <Label fx:id="lblRecomendado" layoutX="180.0" layoutY="230.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="265.0" styleClass="detalle-titulo" text="Estado" />
        <Label fx:id="lblEstado" layoutX="180.0" layoutY="265.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="300.0" styleClass="detalle-titulo" text="Consola" />
        <Label fx:id="lblConsola" layoutX="180.0" layoutY="300.0" styleClass="detalle-valor" />

        <Label layoutX="20.0" layoutY="335.0" styleClass="detalle-titulo" text="Imagen" />

        <!-- StackPane para superponer el label "No hay imagen" sobre la ImageView -->
        <StackPane layoutX="20.0" layoutY="365.0">
            <ImageView fx:id="imgDetalle" fitHeight="239.0" fitWidth="216.0" preserveRatio="true" />
            <!-- Este label se superpone a la imagen cuando no hay imagen -->
            <Label fx:id="lblNoImagen" prefHeight="237.0" prefWidth="219.0" styleClass="detalle-valor" text="No hay imagen" visible="false" />
        </StackPane>
    </AnchorPane>

</AnchorPane>
