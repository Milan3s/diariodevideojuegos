<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="909.0" prefWidth="1423.0" styleClass="mainFxmlClass" stylesheets="@../styles/juegos.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.JuegosController">
    <!-- Título -->
    <Text fx:id="tituloJuegos" layoutX="30.0" layoutY="40.0" styleClass="inicio-titulo" text="Juegos" />
    <!-- HBox para los botones: Añadir, Editar, Eliminar -->
    <HBox alignment="CENTER_LEFT" layoutX="376.0" layoutY="120.0" prefHeight="42.0" prefWidth="325.0" spacing="10.0">
        <!-- Botón Añadir -->
        <Button layoutX="10.0" onAction="#abrirModalAgregarJuego" prefHeight="42.0" prefWidth="105.0" styleClass="juegos-button" text="Añadir" />
        <!-- Botón Editar -->
        <Button fx:id="btnEditar" onAction="#editarJuego" prefHeight="42.0" prefWidth="109.0" styleClass="juegos-button" text="Editar" />
        <!-- Botón Eliminar -->
        <Button fx:id="btnEliminar" onAction="#eliminarJuego" prefHeight="42.0" prefWidth="116.0" styleClass="juegos-button" text="Eliminar" />
    </HBox>
    <!-- HBox para los ComboBox de Estado y Consola -->
    <HBox layoutX="30.0" layoutY="108.0" prefHeight="54.0" prefWidth="325.0" spacing="10.0">
        <!-- ComboBox Estado -->
        <ComboBox fx:id="comboEstado" prefHeight="52.0" prefWidth="155.0" promptText="Estados" styleClass="combo-box-style" />
        <!-- ComboBox Consola -->
        <ComboBox fx:id="comboConsola" prefHeight="27.0" prefWidth="161.0" promptText="Consolas" styleClass="combo-box-style" />
    </HBox>
    <!-- ListView -->
    <ListView fx:id="listaJuegos" layoutX="30.0" layoutY="171.0" prefHeight="732.0" prefWidth="332.0" styleClass="lista-juegos" />
    <!-- Detalles (Card) -->
    <AnchorPane layoutX="376.0" layoutY="171.0" prefHeight="732.0" prefWidth="944.0" styleClass="detalle-card">
        <Label layoutX="20.0" layoutY="356.0" styleClass="detalle-titulo" text="Imagen" />
        <!-- StackPane para la imagen y video -->
        <StackPane layoutX="20.0" layoutY="389.0" prefHeight="239.0" prefWidth="216.0">
            <!-- Este label se superpone a la imagen cuando no hay imagen -->
            <Label fx:id="lblNoImagen" prefHeight="237.0" prefWidth="219.0" styleClass="detalle-valor" text="No hay imagen" visible="false" />
            <!-- Imagen de fondo (Imagen del juego) -->
            <ImageView fx:id="imgDetalle" fitHeight="239.0" fitWidth="216.0" preserveRatio="true" />
        </StackPane>
        <!-- Otros campos (Detalles del juego) -->
        <HBox layoutX="20.0" layoutY="21.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label prefHeight="25.0" prefWidth="62.0" styleClass="detalle-titulo" text="Nombre :" />
                <Label fx:id="lblNombre" prefHeight="25.0" prefWidth="584.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <HBox layoutX="23.0" layoutY="56.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label prefHeight="25.0" prefWidth="68.0" styleClass="detalle-titulo" text="Género :" />
                <Label fx:id="lblGenero" prefHeight="25.0" prefWidth="634.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <!-- Otros detalles -->
        <HBox layoutX="24.0" layoutY="90.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label prefHeight="25.0" prefWidth="75.0" styleClass="detalle-titulo" text="Editor :" />
                <Label fx:id="lblEditor" prefHeight="25.0" prefWidth="640.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <HBox layoutX="24.0" layoutY="122.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label prefHeight="28.0" prefWidth="91.0" styleClass="detalle-titulo" text="Desarrollador :" />
                <Label fx:id="lblDesarrollador" prefHeight="25.0" prefWidth="564.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <HBox layoutX="23.0" layoutY="156.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label styleClass="detalle-titulo" text="Fecha de lanzamiento :" />
                <Label fx:id="lblFecha" prefHeight="25.0" prefWidth="513.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <HBox layoutX="24.0" layoutY="187.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label prefHeight="25.0" prefWidth="137.0" styleClass="detalle-titulo" text="Modo de juego :" />
                <Label fx:id="lblModo" prefHeight="25.0" prefWidth="593.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <HBox layoutX="22.0" layoutY="217.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label prefHeight="25.0" prefWidth="113.0" styleClass="detalle-titulo" text="Recomendado :" />
                <Label fx:id="lblRecomendado" prefHeight="25.0" prefWidth="593.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <HBox layoutX="24.0" layoutY="248.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label prefHeight="25.0" prefWidth="80.0" styleClass="detalle-titulo" text="Estado :" />
                <Label fx:id="lblEstado" prefHeight="25.0" prefWidth="646.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <HBox layoutX="23.0" layoutY="286.0" prefHeight="25.0" prefWidth="683.0">
            <children>
                <Label prefHeight="25.0" prefWidth="94.0" styleClass="detalle-titulo" text="Consola :" />
                <Label fx:id="lblConsola" alignment="TOP_LEFT" prefHeight="25.0" prefWidth="640.0" styleClass="detalle-valor" />
            </children>
        </HBox>
        <Label layoutX="247.0" layoutY="356.0" styleClass="detalle-titulo" text="Video" />
        <StackPane layoutX="247.0" layoutY="389.0" prefHeight="252.0" prefWidth="356.0">
            <children>
                <ImageView fitHeight="301.0" fitWidth="504.0" pickOnBounds="true" preserveRatio="true" />
                <!-- Video encima de la imagen -->
                <MediaView fx:id="videoDetalle" fitHeight="300.0" fitWidth="500.0" />
            </children>
        </StackPane>
    </AnchorPane>

</AnchorPane>
